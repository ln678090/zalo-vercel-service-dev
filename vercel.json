{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/login-qr",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/send-by-phone",
      "dest": "/api/index.js"
    }
  ]
}